# Proxion Messenger — environment template
# Copy to .env and adjust. Every value is optional: with no .env at all the
# gateway runs locally on http://localhost:8080 with no pod backing.
# (.env is gitignored — this template is safe to commit.)

# ─── Network ─────────────────────────────────────────────────────────────────
# PROXION_HTTP_PORT=8080
# PROXION_WS_PORT=7474

# Public URLs advertised to browsers and federation peers. Required when
# running behind a reverse proxy (Caddy, nginx) or exposing the gateway to
# the internet; leave unset for local use.
# PROXION_PUBLIC_URL=wss://chat.example.com
# PROXION_HTTP_PUBLIC_URL=https://chat.example.com

# Direct TLS (skip if a reverse proxy terminates TLS for you):
# PROXION_SSL_CERT=/certs/fullchain.pem
# PROXION_SSL_KEY=/certs/privkey.pem

# ─── Storage ─────────────────────────────────────────────────────────────────
# Where identity keys and the local message store live.
# Default: ~/.proxion (the Tauri desktop app manages this for you).
# PROXION_DATA_DIR=

# ─── Solid Pod (optional) ────────────────────────────────────────────────────
# Pod sign-in normally happens in the browser via Solid OIDC — no credentials
# belong here. Set these ONLY for headless/CLI/Docker deployments against a
# Community Solid Server account:
# PROXION_CSS_URL=
# PROXION_CSS_EMAIL=
# PROXION_CSS_PASSWORD=

# ─── Federation safety ───────────────────────────────────────────────────────
# Allow relaying to localhost/LAN gateways. Only enable for local two-gateway
# development (see scripts/run_local_pair.py); keep 0 on anything internet-facing.
PROXION_ALLOW_PRIVATE_RELAY=0

# Solid access grants (delegated third-party pod access). Off by default;
# enable only if your deployment profile requires third-party data sharing.
PROXION_ENABLE_ACCESS_GRANTS=0

# ─── Advanced ────────────────────────────────────────────────────────────────
# Hardening, Solid SDK migration stages, relay fallback, and every other knob
# are documented in docs/SELF_HOSTING.md and docs/security/.
