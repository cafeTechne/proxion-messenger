# Proxion Environment Template
# Copy this to .env and fill in your values.
# .env is gitignored — this file is safe to commit.

# ─── Infrastructure ───────────────────────────────────────────────────────────
# Bridge VM (Alpine) — sits on SovereignSwitch Hyper-V internal network.
# Default subnet is 172.16.0.0/24; Alpine gets .42, host gateway gets .1.
BRIDGE_IP=172.16.0.42

# VPS — remote seedbox / egress node (your Hetzner/provider public IP)
VPS_IP=your.vps.ip.here
VPS_SSH_USER=root

# SSH key used by the ingest daemon, recover.py, and the socks5 tunnel.
# Generate: ssh-keygen -t ed25519 -f %USERPROFILE%\.ssh\id_proxion_auto
# Then copy the public key to Alpine (/root/.ssh/authorized_keys) and your VPS.
SSH_KEY=C:\Users\yourname\.ssh\id_proxion_auto

# ─── Transmission (running on VPS) ────────────────────────────────────────────
TRANSMISSION_USER=youruser
TRANSMISSION_PASS=change-me-to-something-strong
VPS_HOME_USER=youruser
VPS_DOWNLOAD_DIR=/home/youruser/transmission/downloads

# ─── *arr API Keys ────────────────────────────────────────────────────────────
# Find each key in the app: Settings → General → Security → API Key
RADARR_API_KEY=
SONARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=

# ─── Local Media Paths ────────────────────────────────────────────────────────
# STASH_ROOT: Proxion runtime data (app configs, databases). Inside the project is fine.
# MEDIA_*: Point at your actual media drives.
STASH_ROOT=C:/Users/yourname/Desktop/Proxion/stash
# CORE_STORAGE is used by docker-compose files for AdGuard, Vaultwarden, Syncthing mounts.
# proxion-core/storage/ is gitignored (runtime app data); this path just needs to exist on your machine.
CORE_STORAGE=C:/Users/yourname/Desktop/Proxion/proxion-core/storage
MEDIA_MOVIES=D:/video/MOVIES
MEDIA_MUSIC=D:/music
MEDIA_SHOWS=D:/video/SHOWS
MEDIA_MUSIC_VIDEOS=D:/video/MUSIC_VIDEOS
MEDIA_PHOTOS=D:/Photos
MEDIA_STORAGE_I=D:/
MEDIA_STORAGE_E=E:/

# ─── Ingest Daemon Staging Paths ──────────────────────────────────────────────
# Local Windows paths where downloads land before the *arr apps import them.
# Tip: put LIDARR_STAGING on the same drive as MEDIA_MUSIC so moves are instant.
LOCAL_DOWNLOADS=C:\Users\yourname\Downloads
LIDARR_STAGING=D:\music\_staging
SONARR_STAGING=C:\Users\yourname\Downloads\sonarr
RADARR_STAGING=C:\Users\yourname\Downloads\radarr

# ─── Ingest Daemon Tuning ─────────────────────────────────────────────────────
# All optional — defaults shown. Uncomment to override.
#MAX_CONCURRENT_DOWNLOADS=5
#POLL_INTERVAL=30
#RPC_TUNNEL_PORT=19091
#TRANSMISSION_PORT=9091

# ─── Solid Pod (browser-side OIDC) ───────────────────────────────────────────
# Pod authentication is handled in the browser via Solid OIDC — no credentials
# needed here. Users sign in at first launch via the onboarding "Sign in with
# Solid Pod" button. The gateway never sees pod credentials.
#
# For integration tests against real pods, set these in your shell (not .env):
#   TEST_POD_A_URL=https://yourname.solidcommunity.net/
#   TEST_POD_B_URL=https://other.solidcommunity.net/

# ─── pod.js Vitest test credentials (written by scripts/provision_test_pod.py) ──
# These go in web/.env.test (gitignored), NOT here.
# To provision: start Docker css-alice, then run:
#   docker compose -f docker-compose.test.yml up -d css-alice
#   python scripts/provision_test_pod.py
# Override CSS URL / credentials with env vars:
#   TEST_CSS_URL=http://localhost:3001  (default)
#   TEST_POD_EMAIL=proxion-test@example.com  (default)
#   TEST_POD_PASSWORD=proxion-test-pw-9981  (default)
# web/.env.test is populated with:
#   TEST_CSS_ISSUER, TEST_CSS_CLIENT_ID, TEST_CSS_CLIENT_SECRET,
#   TEST_STORAGE_ROOT, TEST_WEBID

# ─── VPS / DuckDNS ───────────────────────────────────────────────────────────
# DuckDNS hostname that points to your VPS (used by NaiveProxy / Caddy on VPS)
DUCKDNS_DOMAIN=your-hostname.duckdns.org

# ─── Proxion Gateway (docker-compose.yml) ────────────────────────────────────
# Public WebSocket URL shown to users (wss:// for TLS, ws:// for local)
PROXION_PUBLIC_URL=wss://chat.example.com
# CSS pod credentials (headless/CLI/Docker use only).
# When running the Tauri desktop app, credentials are entered in the setup wizard
# and stored in the OS keychain — do NOT set these here for end-user installs.
PROXION_CSS_EMAIL=gateway@example.com
PROXION_CSS_PASSWORD=changeme
# Optional TLS — mount certs via Docker volume and set these paths:
# PROXION_SSL_CERT=/certs/fullchain.pem
# PROXION_SSL_KEY=/certs/privkey.pem
# Override the HTTP base URL advertised to federation peers.
# Required when running behind a reverse proxy (Caddy, nginx) where the public URL
# differs from the internal port.  Leave unset for direct-port or local deployments.
# PROXION_HTTP_PUBLIC_URL=https://chat.example.com

# ─── Local Dev / Federation Testing ─────────────────────────────────────────
# Override ports and data dir to run a second gateway instance side-by-side.
# See scripts/run_gateway_b.ps1 for the two-gateway local test setup.
# PROXION_WS_PORT=7474
# PROXION_HTTP_PORT=8080
# PROXION_DATA_DIR=%USERPROFILE%\.proxion

# Allow relay to localhost/LAN gateways (set to 1 for local two-gateway testing only).
# Leave at 0 (default) in any internet-facing deployment.
PROXION_ALLOW_PRIVATE_RELAY=0

# ─── Solid SDK Migration Controls ────────────────────────────────────────────
# These flags govern the phased migration from custom Solid auth/data paths to
# the official Inrupt SDK.  Change them only when you understand the implications.
#
# Auth mode: how the gateway acquires Pod access tokens.
#   legacy         — current behaviour (ES256 DPoP client-credentials POST)
#   inrupt_bridge  — Inrupt SDK node adapter (NotImplementedError until bridge lands)
#   auto           — try bridge first; fall back to legacy on transport errors only.
#                    Auth/nonce failures are NOT retried via legacy.
PROXION_SOLID_AUTH_MODE=legacy
#
# Notifications mode: how the gateway receives Pod change events.
#   legacy — HTTP polling only
#   sdk    — WebSocketChannel2023 via @inrupt/solid-client-notifications (stub)
#   auto   — SDK first, fall back to polling on error (default)
PROXION_SOLID_NOTIFS_MODE=auto
#
# Dual-read shadow mode: when 1, GET results from the legacy path are compared
# with a stub adapter call.  Mismatches are logged and counted.  Safe at 0.
PROXION_SOLID_DUAL_READ=0
#
# Cutover stage controls which legacy path usages are allowed:
#   0 — shadow / pre-canary  (legacy fully allowed, DEBUG log only)
#   1 — canary               (legacy allowed, DEBUG log)
#   2 — broad rollout        (legacy secondary; WARNING on legacy usage)
#   3 — full cutover         (legacy path blocked; PROXION_SOLID_EMERGENCY_OVERRIDE=1 to bypass)
PROXION_SOLID_CUTOVER_STAGE=0
#
# Enforce SDK support policy during install/CI.
# When 1, the check:solid-sdk npm script must pass before tests run.
PROXION_REQUIRE_SUPPORTED_SOLID_SDK=1
#
# Access grants (delegated third-party access patterns).  Disabled by default.
# Set to 1 only when your deployment profile requires third-party data sharing.
PROXION_ENABLE_ACCESS_GRANTS=0
